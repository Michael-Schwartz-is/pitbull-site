---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="ג'יוגיטסו ברזילאי במרכז תל אביב אצל רועי נאמן ניסיון של 20 שנה. אצלנו מתאמנים גברים ונשים שמכיניסים כושר, תנועתיות, קרביות וביטחון עצמי לחיים שלהם, מפתחים הרגלים חיוביים, מייצרים איזון פנימי ותחושה טובה בין אימון לאימון." />
  <meta property="og:title" content={title} />
  <meta property="og:type" content="website" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;700;800;900&display=swap" rel="stylesheet" />
  <title>{title}</title>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  :root {
    --orange-red: #ff681a;
    --black: #181818;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Heebo', Arial, 'Helvetica Neue', Helvetica, sans-serif;
    color: var(--black);
    direction: rtl;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  h1 {
    font-size: 44px;
    line-height: 120%;
    font-weight: 700;
  }

  h2 {
    font-size: 36px;
    line-height: 130%;
    font-weight: 700;
    margin-bottom: 10px;
  }

  h3 {
    font-size: 24px;
    line-height: 130%;
    font-weight: 700;
  }

  p {
    font-size: 18px;
    line-height: 160%;
  }

  img {
    max-width: 100%;
    display: block;
  }

  /* Navbar */
  .navbar {
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    background-color: #ffffff26;
    align-items: center;
    width: 100vw;
    height: auto;
    min-height: 4.5rem;
    padding-left: 5%;
    padding-right: 5%;
    display: flex;
    position: fixed;
    top: 0;
    z-index: 100;
  }

  .navbar-container {
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    margin-left: auto;
    margin-right: auto;
    display: flex;
  }

  .navbar-logo {
    color: var(--black);
    align-items: flex-end;
    padding-left: 0;
    font-size: 40px;
    font-weight: 700;
    line-height: 0.7;
    display: flex;
    text-decoration: none;
  }

  .navbar-logo .smaller {
    font-size: 20px;
    font-weight: 400;
  }

  .navbar-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* CTA Button */
  .main-cta {
    background-color: var(--orange-red);
    color: #fff;
    border-radius: 4px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-top: 14px;
    padding: 22px;
    font-size: 20px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .main-cta:hover {
    opacity: 0.9;
  }

  .main-cta.is-small {
    margin-top: 0;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .is-desktop {
    display: inline;
  }

  /* Sections */
  .section {
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100vw;
    padding: 64px 32px;
    display: flex;
    position: relative;
  }

  .section.hero {
    justify-content: flex-start;
    align-items: center;
    height: 80vh;
    display: flex;
  }

  .section.teacher {
    background-color: #e7e7e7;
    padding-top: 81px;
    padding-bottom: 81px;
  }

  .section.whynow {
    background-image: linear-gradient(#0009, #0009), url('/images/seminar-group.jpg');
    background-position: 0 0, 50% 0;
    background-repeat: repeat, no-repeat;
    background-size: auto, cover;
    background-attachment: scroll, fixed;
    height: 85vh;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .section.reasons-section {
    padding-bottom: 77px;
  }

  .section.contact {
    background-image: linear-gradient(#00000078, #00000078), url('/images/group-photo.jpg');
    background-position: 0 0, 0 0;
    background-size: auto, auto;
    background-attachment: scroll, fixed;
    min-height: 100vh;
  }

  /* Wrappers */
  .wrapper {
    justify-content: center;
    width: 100%;
    max-width: 1280px;
    display: flex;
  }

  .wrapper.hero {
    color: #fff;
    justify-content: center;
    align-items: flex-start;
    height: 100%;
    display: flex;
  }

  .wrapper.time {
    text-align: center;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
  }

  .wrapper.teacher {
    justify-content: space-between;
  }

  .wrapper.testamonials {
    flex-direction: column;
    justify-content: flex-start;
  }

  .wrapper.why-now {
    color: #fff;
    justify-content: flex-start;
  }

  .wrapper.start {
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
  }

  .wrapper.what-learn {
    flex-direction: column;
    align-items: flex-start;
  }

  .wrapper.reasons-wrap {
    flex-direction: column;
    align-items: center;
    padding-top: 58px;
  }

  .wrapper.contact {
    color: #fff;
    justify-content: space-between;
    align-items: center;
  }

  /* Hero content */
  .text-wrap {
    text-align: center;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    max-width: 700px;
    display: flex;
    z-index: 1;
  }

  .text-block {
    font-size: 24px;
    line-height: 140%;
  }

  .img-bg-wrap {
    z-index: -1;
    position: absolute;
    inset: 0;
  }

  .bg-img {
    object-fit: cover;
    object-position: 0% 0%;
    width: 100%;
    height: 100%;
  }

  .bg-overlay {
    background-color: #28394c63;
    position: absolute;
    inset: 0;
  }

  .hero-logo {
    width: 12vw;
  }

  /* Title wrap */
  .title-wrap {
    text-align: center;
    width: 60%;
    margin-top: 49px;
    margin-bottom: 49px;
  }

  .title-wrap.align-right {
    text-align: right;
  }

  /* Schedule Table */
  .schedule-table {
    border: 1px solid #ff681a66;
    width: 100%;
    font-size: 18px;
    display: flex;
    position: relative;
    overflow: auto;
  }

  .day-column {
    flex: 1;
  }

  .slot {
    text-align: center;
    border: 1px solid #ff681a2e;
    min-height: 80px;
    padding: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .slot.bold {
    font-weight: 700;
  }

  .slot.no-padding {
    padding: 0;
  }

  .slot.friday-highlight {
    background-image: linear-gradient(to bottom, #ffffffe3, #ffffffe3), repeating-linear-gradient(33deg, var(--orange-red), #000 10%);
  }

  .slot.double {
    min-height: 160px;
  }

  .schedule-logo {
    width: 50px;
  }

  .label-row {
    display: flex;
    flex-direction: column;
  }

  .label-row.desktop {
    display: block;
  }

  .label-row.mobile {
    display: none;
  }

  .label-text {
    font-weight: 700;
  }

  /* Testimonials */
  .testemonials-wrap {
    flex-direction: column;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 58px;
    display: flex;
  }

  .person {
    background-color: #f6f3f3;
    align-items: center;
    width: 50%;
    margin-top: 15px;
    margin-bottom: 15px;
    margin-right: 60px;
    padding: 22px;
    display: flex;
  }

  .testi-wrap {
    border-radius: 210px;
    flex: none;
    width: 200px;
    height: 200px;
    margin-right: 34px;
    overflow: hidden;
  }

  .testi-img {
    object-fit: cover;
    border: 0 solid #000;
    width: 100%;
    height: 100%;
  }

  .testi-text {
    margin-left: 16px;
  }

  .testa-name {
    text-align: right;
    font-size: 20px;
    font-weight: 700;
    line-height: 150%;
  }

  .spacere {
    text-align: center;
    padding-top: 34px;
    padding-bottom: 64px;
  }

  /* Teacher */
  .text-wrapper {
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding-top: 25px;
    padding-bottom: 25px;
    padding-right: 32px;
    display: flex;
    flex: 1;
  }

  .image-wrapper {
    flex: 1;
  }

  .paragraph-2 {
    max-width: 611px;
  }

  .teacher-img {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  /* Why now */
  .footer-image {
    display: none;
  }

  .footer-image img {
    width: 100%;
    object-fit: cover;
  }

  /* Stages / How to start */
  .stag-er {
    flex-flow: wrap;
    margin-top: 63px;
    display: flex;
  }

  .stage {
    flex: 1;
    padding-right: 56px;
  }

  .orange {
    background-color: var(--orange-red);
    border-radius: 50%;
    flex: none;
    justify-content: center;
    align-items: center;
    width: 64px;
    height: 64px;
    margin-right: 15px;
    line-height: 0;
    display: flex;
  }

  .big-no {
    color: #fff;
    font-size: 25px;
    line-height: 100%;
  }

  .padd {
    margin-top: 31px;
    margin-bottom: 10px;
  }

  .wide {
    text-align: center;
    width: 100%;
    margin-top: 69px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Lessons */
  .lessons-div {
    flex-wrap: wrap;
    display: flex;
  }

  .lesson {
    flex: 0 auto;
    width: 30%;
    margin: 6px;
    padding: 6px;
  }

  .lesson-img {
    object-fit: cover;
    border: 0 solid #000;
    width: 100%;
    height: 230px;
    margin-bottom: 20px;
  }

  /* Reasons */
  .reasons-grid {
    justify-content: center;
    width: 100%;
    margin-top: 23px;
    display: flex;
  }

  .reason {
    background-color: #e6e6e6;
    flex-direction: row;
    flex: 1;
    align-items: flex-start;
    margin-right: 24px;
    padding: 16px 16px 10px;
    display: flex;
  }

  .text-div {
    flex: 1;
    padding-right: 12px;
  }

  /* Contact */
  .contact-inner {
    flex: 1;
  }

  .contact-logo-wrap {
    width: 410px;
  }

  .contact-logo {
    object-fit: cover;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .contact-links {
    padding-top: 22px;
    display: flex;
  }

  .link-block {
    color: #000;
    background-color: #ffffffb0;
    border: 1px solid #ffffffc9;
    border-radius: 4px;
    align-items: center;
    margin-right: 6px;
    padding: 9px 15px;
    display: flex;
    text-decoration: none;
  }

  .link-block:hover {
    background-color: #ffffff4f;
  }

  .link-icon {
    width: 40px;
    height: 40px;
    margin-right: 10px;
  }

  .map-div {
    color: #000;
    width: 50%;
    min-height: 400px;
  }

  .map-div iframe {
    width: 100%;
    height: 100%;
    min-height: 400px;
    border: 0;
  }

  .spacer {
    height: 20px;
  }

  .link {
    color: inherit;
  }

  /* Footer */
  .footer {
    color: #fff;
    background-color: #000;
    justify-content: center;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 12px;
    display: flex;
  }

  /* Scroll animation helper */
  .scroll-animate {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .scroll-animate.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ===================== */
  /* RESPONSIVE            */
  /* ===================== */

  @media screen and (max-width: 991px) {
    .wrapper.time {
      flex-direction: row;
    }

    .wrapper.teacher {
      flex-direction: column;
      align-items: center;
    }

    .wrapper.testamonials {
      align-items: center;
    }

    .wrapper.contact {
      flex-direction: column;
      align-items: flex-start;
    }

    .section.time {
      padding-left: 0;
    }

    .title-wrap {
      width: 70%;
      margin-left: auto;
      margin-right: auto;
    }

    .schedule-table {
      position: relative;
    }

    .day-column {
      flex: none;
      min-width: 24vw;
    }

    .label-row.desktop {
      display: none;
    }

    .label-row.mobile {
      display: block;
    }

    .person {
      width: auto;
      max-width: 550px;
      margin-bottom: 36px;
      margin-right: 0;
    }

    .testemonials-wrap {
      flex-direction: column;
      padding-bottom: 0;
    }

    .image-wrapper {
      width: 100%;
    }

    .stag-er {
      flex-direction: column;
      align-items: center;
    }

    .stage {
      flex: 0 auto;
      max-width: 302px;
      margin-bottom: 43px;
      padding-right: 0;
      display: block;
    }

    .stage._01 {
      align-self: flex-start;
    }

    .stage._03 {
      align-self: flex-end;
    }

    .orange {
      margin-bottom: 17px;
    }

    .lessons-div {
      justify-content: center;
    }

    .lesson {
      width: 100%;
      max-width: 450px;
      margin-bottom: 68px;
    }

    .reason {
      flex-direction: column;
      flex: 0 auto;
      max-width: 390px;
      margin-bottom: 20px;
      margin-left: auto;
      margin-right: auto;
    }

    .reasons-grid {
      flex-direction: column;
      justify-content: space-between;
      align-items: stretch;
    }

    .contact-inner {
      margin-bottom: 31px;
    }

    .contact-logo-wrap {
      width: 180px;
    }

    .link-block {
      color: #545250;
      background-color: #fff;
    }

    .map-div {
      width: 100%;
    }

    .wide {
      padding-top: 27px;
    }

    .contact-logo {
      left: 0;
    }
  }

  @media screen and (max-width: 767px) {
    .navbar {
      min-height: 4rem;
    }

    .main-cta {
      text-align: center;
      display: block;
    }

    .section.testa {
      padding-top: 0;
    }

    .section.teacher {
      flex-direction: column;
    }

    .section.whynow {
      background-image: linear-gradient(#0009, #0009);
      background-position: 0 0;
      height: auto;
      padding-top: 0;
      padding-left: 0;
      padding-right: 0;
    }

    .section.contact {
      background-color: #515151;
      background-image: none;
    }

    .section.no-margin {
      padding-bottom: 0;
    }

    .wrapper.time {
      flex-direction: row;
      align-items: flex-start;
      position: relative;
    }

    .wrapper.teacher {
      flex-direction: column-reverse;
    }

    .wrapper.why-now {
      padding-top: 27px;
      padding-left: 32px;
      padding-right: 32px;
    }

    .wrapper.start {
      align-items: center;
    }

    .wrapper.reasons-wrap {
      margin-top: 0;
      padding-top: 0;
    }

    .wrapper.contact {
      margin-top: -307px;
    }

    .title-wrap.align-right {
      margin-right: 0;
    }

    .day-column {
      flex: none;
      min-width: 17ch;
    }

    .slot {
      min-height: 70px;
    }

    .slot.double {
      min-height: 140px;
    }

    .text-block {
      font-size: 19px;
    }

    .footer-image {
      display: block;
    }

    .lessons-div {
      justify-content: flex-start;
    }

    .lesson {
      width: 100%;
      max-width: none;
      padding-left: 0;
    }

    .link-block {
      flex: 1;
    }

    .spacere {
      padding-top: 0;
    }

    .wide {
      margin-top: auto;
      padding-top: 0;
    }
  }

  @media screen and (max-width: 479px) {
    .navbar-logo {
      font-size: 25px;
    }

    .navbar-logo .smaller {
      font-size: 16px;
    }

    .main-cta {
      display: flex;
    }

    .main-cta.is-small {
      padding-top: 14px;
      padding-bottom: 14px;
      font-size: 30px;
    }

    .section {
      padding: 40px 16px 0;
    }

    .section.hero {
      flex-direction: column-reverse;
      height: auto;
      padding-top: 0;
      padding-left: 0;
      padding-right: 0;
    }

    .section.time {
      padding: 0 16px 0 0;
    }

    .section.testa,
    .section.whynow {
      height: auto;
    }

    .section.teacher {
      color: #fff;
      background-color: #000;
      padding-top: 0;
      padding-left: 0;
      padding-right: 0;
      overflow: hidden;
    }

    .section.reasons-section {
      margin-top: 0;
      padding-top: 0;
      padding-bottom: 9px;
    }

    .section.contact {
      min-height: auto;
    }

    .wrapper.hero {
      color: #000;
    }

    .wrapper.time {
      border: 1px solid #ff681a66;
      flex-direction: row;
      align-items: flex-start;
    }

    .wrapper.testamonials {
      text-align: center;
    }

    .wrapper.why-now {
      padding-top: 31px;
    }

    .wrapper.start {
      text-align: right;
    }

    .wrapper.reasons-wrap {
      align-items: center;
      margin-top: 0;
      padding-top: 0;
      padding-bottom: 32px;
    }

    .wrapper.contact {
      margin-top: -46px;
    }

    .text-wrap {
      margin-top: -25vw;
      padding-left: 9px;
      padding-right: 9px;
    }

    .text-block {
      display: none;
    }

    .img-bg-wrap {
      height: 40vh;
      position: relative;
    }

    .bg-img {
      object-position: 30% 0%;
    }

    .title-wrap {
      flex-direction: column;
      align-items: center;
      width: 90%;
      margin-top: 7px;
      margin-bottom: 13px;
      display: flex;
    }

    .schedule-table {
      z-index: 1;
      border-color: transparent;
      flex-direction: row;
    }

    .day-column {
      flex: none;
      min-width: 20vw;
    }

    .slot {
      border: 1px solid #ff681a52;
      min-height: 70px;
    }

    .slot.double {
      min-height: 140px;
    }

    .person {
      flex-direction: column;
      margin-bottom: 28px;
      margin-right: 0;
    }

    .testi-wrap {
      width: 120px;
      height: 120px;
      margin-bottom: 26px;
      margin-right: 0;
    }

    .testi-text {
      margin-left: 0;
    }

    .testa-name {
      text-align: center;
    }

    .text-wrapper {
      padding-left: 16px;
      padding-right: 16px;
    }

    .stag-er {
      width: 100%;
    }

    .reason {
      text-align: center;
      align-items: center;
      margin: 6px;
    }

    .reasons-grid {
      flex-direction: column;
      align-items: center;
    }

    .contact-links {
      width: 100%;
    }

    .contact-logo-wrap {
      width: 140px;
    }

    .link-block {
      flex-direction: column;
      flex: 1;
      justify-content: flex-start;
      margin-top: 13px;
      margin-bottom: 13px;
      padding: 19px;
    }

    .link-icon {
      margin-right: 0;
    }

    .spacere {
      padding-top: 23px;
      padding-bottom: 23px;
    }

    .wide {
      margin-top: 20px;
    }

    .hero-logo {
      width: 50vw;
      margin-bottom: -35px;
    }

    .schedule-logo {
      height: 50px;
    }

    .is-desktop {
      display: none;
    }
  }
</style>
