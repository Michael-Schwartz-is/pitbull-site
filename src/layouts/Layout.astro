  }

  @keyframes ctaPulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(196, 78, 10, 0.4); }
    50% { box-shadow: 0 0 0 12px rgba(196, 78, 10, 0); }
  }

  /* Respect reduced motion */
  @media (prefers-reduced-motion: reduce) {
