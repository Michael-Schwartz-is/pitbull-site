---
interface Props {
  title: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
}

const {
  title,
  description = "ג'יוגיטסו ברזילאי במרכז תל אביב אצל רועי נאמן. ניסיון של 20+ שנה, חגורה שחורה דאן 3, מקום שלישי בעולם. אימונים לכל הרמות – GI, NO-GI, MMA, היאבקות, נשים וילדים.",
  canonicalUrl = Astro.url.href,
  ogImage = "/images/hero-bg.webp",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <!-- SEO -->
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Pitbull Israel - Roi Neeman" />
  <meta name="keywords" content="ג'יוגיטסו, ג'יו ג'יטסו, BJJ, MMA, תל אביב, רועי נאמן, פיטבול, Brazilian Jiu-Jitsu, No-Gi, היאבקות, אומנויות לחימה, martial arts, Tel Aviv" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content="he_IL" />
  <meta property="og:site_name" content="Pitbull Israel BJJ" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Hreflang (for future bilingual) -->
  <link rel="alternate" hreflang="he" href={canonicalUrl} />

  <!-- Google Site Verification -->
  <meta name="google-site-verification" content="fLiaA5T_ykM0RCpBP7Asg72r4jt2JEqAPV4Y3YdwxLw" />

  <!-- Favicon -->
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="apple-touch-icon" href="/images/favicon.png" />

  <!-- Preload hero image for LCP -->
  <link rel="preload" as="image" type="image/webp" href="/images/hero-bg.webp" fetchpriority="high" />

  <!-- Fonts: self-hosted woff2 -->
  <link rel="preload" as="font" type="font/woff2" href="/fonts/heebo-hebrew.woff2" crossorigin />
  <link rel="preload" as="font" type="font/woff2" href="/fonts/heebo-latin.woff2" crossorigin />

  <!-- Structured Data (JSON-LD) for AEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SportsActivityLocation",
    "name": "Pitbull Israel - Brazilian Jiu-Jitsu",
    "alternateName": "פיטבול ישראל - ג'יוגיטסו ברזילאי",
    "description": description,
    "url": canonicalUrl,
    "telephone": "+972542042035",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "רחוב בן שמן 4",
      "addressLocality": "תל אביב",
      "addressCountry": "IL"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 32.075347,
      "longitude": 34.794556
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "18:00", "closes": "21:30" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Monday", "opens": "19:00", "closes": "21:30" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Tuesday", "opens": "08:00", "closes": "21:30" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Wednesday", "opens": "18:30", "closes": "21:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Thursday", "opens": "19:15", "closes": "21:30" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "11:00", "closes": "13:00" }
    ],
    "sameAs": ["https://wa.me/972542042035"],
    "founder": {
      "@type": "Person",
      "name": "Roi Neeman",
      "alternateName": "רועי נאמן",
      "jobTitle": "Head Instructor",
      "description": "Black belt 3rd Dan in Brazilian Jiu-Jitsu, former professional MMA fighter, 3rd place world ranking No-Gi 2007, Wingate certified coach"
    },
    "sport": "Brazilian Jiu-Jitsu",
    "offers": {
      "@type": "Offer",
      "name": "אימון ניסיון",
      "description": "Trial training session",
      "price": "0",
      "priceCurrency": "ILS"
    }
  })} />

  <!-- FAQ Schema for AEO -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "מה זה ג'יו ג'יטסו ברזילאי?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "ג'יו ג'יטסו ברזילאי (BJJ) הוא ספורט לחימה המתמקד בהיאבקות על הקרקע. היתרון הגדול הוא שטכניקה טובה מנצחת כוח, כך שמתאים לכל אחד ללא קשר לגודל או כוח."
        }
      },
      {
        "@type": "Question",
        "name": "האם צריך ניסיון קודם כדי להתחיל?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "לא! אימוני הבסיס שלנו מיועדים למתחילים לחלוטין. תלמדו את העקרונות החשובים מאפס – עמדות מוצא, שליטה על הקרקע, הכנעות והגנה עצמית."
        }
      },
      {
        "@type": "Question",
        "name": "איפה המכון ומה שעות הפעילות?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "המכון נמצא ברחוב בן שמן 4, תל אביב. אימונים מתקיימים כל יום בשבוע – ימים א'-ה' בערב ויום שישי בבוקר (מזרון פתוח וניידות)."
        }
      },
      {
        "@type": "Question",
        "name": "מי המאמן?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "רועי נאמן, חגורה שחורה דאן 3, התמקצע במכון באהה גרייסי פיטבול בסן-דייגו. 8 שנות תחרות מקצועית בארה\"ב, מעל 100 טורנירים, מקום שלישי בעולם 2007 No-Gi. מאמן מוסמך וינגייט."
        }
      }
    ]
  })} />

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-E7TG0RFBLP"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-E7TG0RFBLP');
  </script>

  <!-- Microsoft Clarity -->
  <script is:inline>
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window, document, "clarity", "script", "cyne4c84wq");
  </script>
</head>
<body>
  <slot />
</body>
</html>

<style is:global>
  /* Heebo — self-hosted, Hebrew subset */
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/heebo-hebrew.woff2') format('woff2');
    unicode-range: U+0307-0308, U+0590-05FF, U+200C-2010, U+20AA, U+25CC, U+FB1D-FB4F;
  }
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/fonts/heebo-hebrew.woff2') format('woff2');
    unicode-range: U+0307-0308, U+0590-05FF, U+200C-2010, U+20AA, U+25CC, U+FB1D-FB4F;
  }
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 800;
    font-display: swap;
    src: url('/fonts/heebo-hebrew.woff2') format('woff2');
    unicode-range: U+0307-0308, U+0590-05FF, U+200C-2010, U+20AA, U+25CC, U+FB1D-FB4F;
  }
  /* Heebo — self-hosted, Latin subset */
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 400;
    font-display: swap;
    src: url('/fonts/heebo-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 700;
    font-display: swap;
    src: url('/fonts/heebo-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }
  @font-face {
    font-family: 'Heebo';
    font-style: normal;
    font-weight: 800;
    font-display: swap;
    src: url('/fonts/heebo-latin.woff2') format('woff2');
    unicode-range: U+0000-00FF, U+0131, U+0152-0153, U+02BB-02BC, U+02C6, U+02DA, U+02DC, U+0304, U+0308, U+0329, U+2000-206F, U+20AC, U+2122, U+2191, U+2193, U+2212, U+2215, U+FEFF, U+FFFD;
  }

  :root {
    --orange-red: #c44e0a;
    --black: #181818;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'Heebo', Arial, 'Helvetica Neue', Helvetica, sans-serif;
    color: var(--black);
    direction: rtl;
    overflow-x: hidden;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  h1 {
    font-size: 44px;
    line-height: 120%;
    font-weight: 700;
  }

  h2 {
    font-size: 36px;
    line-height: 130%;
    font-weight: 700;
    margin-bottom: 10px;
  }

  h3 {
    font-size: 24px;
    line-height: 130%;
    font-weight: 700;
  }

  p {
    font-size: 18px;
    line-height: 160%;
  }

  img {
    max-width: 100%;
    display: block;
  }

  /* Navbar */
  .navbar {
    -webkit-backdrop-filter: blur(5px);
    backdrop-filter: blur(5px);
    background-color: #ffffff26;
    align-items: center;
    width: 100vw;
    height: auto;
    min-height: 4.5rem;
    padding-left: 5%;
    padding-right: 5%;
    display: flex;
    position: fixed;
    top: 0;
    z-index: 100;
  }

  .navbar-container {
    justify-content: space-between;
    align-items: center;
    width: 100%;
    height: 100%;
    margin-left: auto;
    margin-right: auto;
    display: flex;
  }

  .navbar-logo {
    color: var(--black);
    align-items: flex-end;
    padding-left: 0;
    font-size: 40px;
    font-weight: 700;
    line-height: 0.7;
    display: flex;
    text-decoration: none;
  }

  .navbar-logo .smaller {
    font-size: 20px;
    font-weight: 400;
  }

  .navbar-buttons {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  /* CTA Button */
  .main-cta {
    background-color: var(--orange-red);
    color: #fff;
    border-radius: 4px;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    margin-top: 14px;
    padding: 22px;
    font-size: 20px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    display: inline-block;
    text-align: center;
  }

  .main-cta:hover {
    opacity: 0.9;
  }

  .main-cta.is-small {
    margin-top: 0;
    padding-top: 8px;
    padding-bottom: 8px;
  }

  .is-desktop {
    display: inline;
  }

  /* Sections */
  .section {
    flex-direction: column;
    justify-content: center;
    align-items: center;
    width: 100vw;
    padding: 64px 32px;
    display: flex;
    position: relative;
  }

  .section.hero {
    justify-content: flex-start;
    align-items: center;
    height: 80vh;
    display: flex;
  }

  .section.teacher {
    background-color: #e7e7e7;
    padding-top: 81px;
    padding-bottom: 81px;
  }

  .section.whynow {
    background-image: linear-gradient(#0009, #0009), url('/images/seminar-group.webp');
    background-position: 0 0, 50% 0;
    background-repeat: repeat, no-repeat;
    background-size: auto, cover;
    background-attachment: scroll, fixed;
    height: 85vh;
    padding-top: 80px;
    padding-bottom: 80px;
  }

  .section.reasons-section {
    padding-bottom: 77px;
  }

  .section.contact {
    background-image: linear-gradient(#00000078, #00000078), url('/images/group-photo.webp');
    background-position: 0 0, 0 0;
    background-size: auto, auto;
    background-attachment: scroll, fixed;
    min-height: 100vh;
  }

  /* Wrappers */
  .wrapper {
    justify-content: center;
    width: 100%;
    max-width: 1280px;
    display: flex;
  }

  .wrapper.hero {
    color: #fff;
    justify-content: center;
    align-items: flex-start;
    height: 100%;
    display: flex;
  }

  .wrapper.time {
    text-align: center;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
  }

  .wrapper.teacher {
    justify-content: space-between;
  }

  .wrapper.testamonials {
    flex-direction: column;
    justify-content: flex-start;
  }

  .wrapper.why-now {
    color: #fff;
    justify-content: flex-start;
  }

  .wrapper.start {
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
  }

  .wrapper.what-learn {
    flex-direction: column;
    align-items: flex-start;
  }

  .wrapper.reasons-wrap {
    flex-direction: column;
    align-items: center;
    padding-top: 58px;
  }

  .wrapper.contact {
    color: #fff;
    justify-content: space-between;
    align-items: center;
  }

  /* Hero content */
  .text-wrap {
    text-align: center;
    flex-direction: column;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
    max-width: 700px;
    display: flex;
    z-index: 1;
  }

  .text-block {
    font-size: 24px;
    line-height: 140%;
  }

  .img-bg-wrap {
    z-index: -1;
    position: absolute;
    inset: 0;
  }

  .bg-img {
    object-fit: cover;
    object-position: 0% 0%;
    width: 100%;
    height: 100%;
  }

  .bg-overlay {
    background-color: #28394c63;
    position: absolute;
    inset: 0;
  }

  .hero-logo {
    width: 12vw;
  }

  /* Title wrap */
  .title-wrap {
    text-align: center;
    width: 60%;
    margin-top: 49px;
    margin-bottom: 49px;
  }

  .title-wrap.align-right {
    text-align: right;
  }

  /* Schedule Table */
  .schedule-table {
    border: 1px solid #ff681a66;
    width: 100%;
    font-size: 18px;
    display: flex;
    position: relative;
    overflow: auto;
  }

  .day-column {
    flex: 1;
  }

  .slot {
    text-align: center;
    border: 1px solid #ff681a2e;
    min-height: 80px;
    padding: 15px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .slot.bold {
    font-weight: 700;
  }

  .slot.no-padding {
    padding: 0;
  }

  .slot.friday-highlight {
    background-image: linear-gradient(to bottom, #ffffffe3, #ffffffe3), repeating-linear-gradient(33deg, var(--orange-red), #000 10%);
  }

  .slot.double {
    min-height: 160px;
  }

  .schedule-logo {
    width: 50px;
  }

  .label-row {
    display: flex;
    flex-direction: column;
  }

  .label-row.desktop {
    display: block;
  }

  .label-row.mobile {
    display: none;
  }

  .label-text {
    font-weight: 700;
  }

  blockquote {
    font-style: normal;
    margin: 0;
    font-size: 18px;
    line-height: 160%;
  }

  /* Testimonials */
  .testemonials-wrap {
    flex-direction: column;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 58px;
    display: flex;
  }

  .person {
    background-color: #f6f3f3;
    align-items: center;
    width: 50%;
    margin-top: 15px;
    margin-bottom: 15px;
    margin-right: 60px;
    padding: 22px;
    display: flex;
  }

  .testi-wrap {
    border-radius: 210px;
    flex: none;
    width: 200px;
    height: 200px;
    margin-right: 34px;
    overflow: hidden;
  }

  .testi-img {
    object-fit: cover;
    border: 0 solid #000;
    width: 100%;
    height: 100%;
  }

  .testi-text {
    margin-left: 16px;
  }

  .testa-name {
    text-align: right;
    font-size: 20px;
    font-weight: 700;
    line-height: 150%;
  }

  .spacere {
    text-align: center;
    padding-top: 34px;
    padding-bottom: 64px;
  }

  /* Teacher */
  .text-wrapper {
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    padding-top: 25px;
    padding-bottom: 25px;
    padding-right: 32px;
    display: flex;
    flex: 1;
  }

  .image-wrapper {
    flex: 1;
  }

  .paragraph-2 {
    max-width: 611px;
  }

  .teacher-img {
    object-fit: cover;
    width: 100%;
    height: 100%;
  }

  /* Why now */
  .footer-image {
    display: none;
  }

  .footer-image img {
    width: 100%;
    object-fit: cover;
  }

  /* Stages / How to start */
  .stag-er {
    flex-flow: wrap;
    margin-top: 63px;
    display: flex;
  }

  .stage {
    flex: 1;
    padding-right: 56px;
  }

  .orange {
    background-color: var(--orange-red);
    border-radius: 50%;
    flex: none;
    justify-content: center;
    align-items: center;
    width: 64px;
    height: 64px;
    margin-right: 15px;
    line-height: 0;
    display: flex;
  }

  .big-no {
    color: #fff;
    font-size: 25px;
    line-height: 100%;
  }

  .padd {
    margin-top: 31px;
    margin-bottom: 10px;
  }

  .wide {
    text-align: center;
    width: 100%;
    margin-top: 69px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Lessons */
  .lessons-div {
    flex-wrap: wrap;
    display: flex;
  }

  .lesson {
    flex: 0 auto;
    width: 30%;
    margin: 6px;
    padding: 6px;
  }

  .lesson-img {
    object-fit: cover;
    border: 0 solid #000;
    width: 100%;
    height: 230px;
    margin-bottom: 20px;
  }

  /* Reasons */
  .reasons-grid {
    justify-content: center;
    width: 100%;
    margin-top: 23px;
    display: flex;
  }

  .reason {
    background-color: #e6e6e6;
    flex-direction: row;
    flex: 1;
    align-items: flex-start;
    margin-right: 24px;
    padding: 16px 16px 10px;
    display: flex;
  }

  .text-div {
    flex: 1;
    padding-right: 12px;
  }

  /* Contact */
  .contact-inner {
    flex: 1;
  }

  .contact-logo-wrap {
    width: 410px;
  }

  .contact-logo {
    object-fit: cover;
    width: 100%;
    height: 100%;
    position: relative;
  }

  .contact-links {
    padding-top: 22px;
    display: flex;
  }

  .link-block {
    color: #000;
    background-color: #ffffffb0;
    border: 1px solid #ffffffc9;
    border-radius: 4px;
    align-items: center;
    margin-right: 6px;
    padding: 9px 15px;
    display: flex;
    text-decoration: none;
  }

  .link-block:hover {
    background-color: #ffffff4f;
  }

  .link-icon {
    width: 40px;
    height: 40px;
    margin-right: 10px;
  }

  .map-div {
    color: #000;
    width: 50%;
    min-height: 400px;
  }

  .map-div iframe {
    width: 100%;
    height: 100%;
    min-height: 400px;
    border: 0;
  }

  .spacer {
    height: 20px;
  }

  .link {
    color: inherit;
  }

  /* Footer */
  .footer {
    color: #fff;
    background-color: #000;
    justify-content: center;
    align-items: center;
    padding-top: 12px;
    padding-bottom: 12px;
    display: flex;
  }

  /* Scroll-triggered fade-in animations */
  .fade-in {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .fade-in-left {
    opacity: 0;
    transform: translateX(40px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .fade-in-left.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .fade-in-right {
    opacity: 0;
    transform: translateX(-40px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  .fade-in-right.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .fade-in-scale {
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
  }

  .fade-in-scale.visible {
    opacity: 1;
    transform: scale(1);
  }

  /* Stagger children */
  .stagger > .fade-in:nth-child(1) { transition-delay: 0s; }
  .stagger > .fade-in:nth-child(2) { transition-delay: 0.12s; }
  .stagger > .fade-in:nth-child(3) { transition-delay: 0.24s; }
  .stagger > .fade-in:nth-child(4) { transition-delay: 0.36s; }
  .stagger > .fade-in:nth-child(5) { transition-delay: 0.48s; }
  .stagger > .fade-in:nth-child(6) { transition-delay: 0.6s; }

  /* Hero entrance — no scroll needed */
  .hero-entrance {
    animation: heroFadeUp 1s ease-out both;
  }

  @keyframes heroFadeUp {
    from {
      opacity: 0;
      transform: translateY(25px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Subtle hover lift on lesson cards */
  .lesson:hover .lesson-img {
    transform: scale(1.03);
  }

  .lesson-img {
    transition: transform 0.4s ease;
  }

  /* CTA pulse on hero */
  .hero-cta-pulse {
