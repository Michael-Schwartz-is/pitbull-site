---
import Layout from '../layouts/Layout.astro';
---

<Layout title="פיטבול - ג'יוגיטסו ברזילאי - רועי נאמן">
  <!-- Navbar -->
  <nav class="navbar" aria-label="ניווט ראשי">
    <div class="navbar-container">
      <a href="/" class="navbar-logo" aria-label="פיטבול ישראל">
        <span>פיטבול</span>
        <span class="smaller">ישראל</span>
      </a>
      <div class="navbar-buttons">
        <a href="#contact" class="main-cta is-small">
          <span class="is-desktop">לתיאום</span> אימון ניסיון
        </a>
      </div>
    </div>
  </nav>

  <main>
  <!-- Hero -->
  <header class="section hero">
    <div class="wrapper hero">
      <div class="text-wrap hero-entrance">
        <img src="/images/logo.svg" alt="פיטבול ישראל הלוגו" class="hero-logo" width="200" height="200" />
        <h1>ג'יו ג'יטסו ברזילאי במרכז תל אביב.</h1>
        <div class="text-block">לאמן את הגוף, לאתגר את המוח<br/>ולשחרר את הלחצים של היומיום.</div>
        <a href="#contact" class="main-cta hero-cta-pulse">לתיאום אימון ניסיון</a>
      </div>
    </div>
    <div class="img-bg-wrap">
      <img src="/images/hero-bg.webp" alt="רועי נאמן פיטבול ישראל המורה מדגים תרגיל על תלמיד" class="bg-img" width="2400" height="1163" fetchpriority="high" />
      <div class="bg-overlay"></div>
    </div>
  </header>

  <!-- Schedule -->
  <section id="shcedule" class="section time" aria-label="מערכת שעות">
    <div class="wrapper">
      <div class="title-wrap fade-in">
        <h2>מערכת שעות שבועית</h2>
        <div class="text-block">בואו להתאמן כל יום עם אנשים בעלי ניסיון תחרותי עשיר במרכז תל אביב. אימונים כל יום, <strong>7 ימים בשבוע.</strong></div>
      </div>
    </div>
    <div class="wrapper time">
      <!-- Mobile label row -->
      <div class="label-row mobile" aria-hidden="true">
        <div class="slot no-padding">
          <img src="/images/logo.svg" width="50" height="50" alt="" class="schedule-logo" />
        </div>
        <div class="slot"><div class="label-text">08:00</div></div>
        <div class="slot"><div class="label-text">12:00</div></div>
        <div class="slot"><div class="label-text">18:00</div></div>
        <div class="slot"><div class="label-text">19:15</div></div>
        <div class="slot"><div class="label-text">20:15</div></div>
        <div class="slot"><div class="label-text">21:15</div></div>
      </div>

      <div class="schedule-table fade-in-scale" aria-label="לוח זמנים שבועי">
        <!-- Desktop label column -->
        <div class="label-row desktop" aria-hidden="true">
          <div class="slot no-padding">
            <img src="/images/logo.svg" alt="" class="schedule-logo" width="50" height="50" />
          </div>
          <div class="slot"><div class="label-text">08:00</div></div>
          <div class="slot"><div class="label-text">12:00</div></div>
          <div class="slot"><div class="label-text">18:00</div></div>
          <div class="slot"><div class="label-text">19:15</div></div>
          <div class="slot"><div class="label-text">20:15</div></div>
          <div class="slot"><div class="label-text">21:15</div></div>
        </div>

        <!-- Sunday -->
        <div class="day-column">
          <div class="slot bold"><div>יום ראשון</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>דרילים</div></div>
          <div class="slot"><div>אימון בסיס</div></div>
          <div class="slot"><div>MMA</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Monday -->
        <div class="day-column">
          <div class="slot bold"><div>יום שני</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>19:00<br/>NO GI</div></div>
          <div class="slot"><div>האבקות</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Tuesday -->
        <div class="day-column">
          <div class="slot bold"><div>יום שלישי</div></div>
          <div class="slot"><div>אימון בוקר</div></div>
          <div class="slot"><div>אימון צהריים</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>19:15<br/>אימון פונקציונאלי</div></div>
          <div class="slot"><div>19:30<br/>BJJ-GI</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Wednesday -->
        <div class="day-column">
          <div class="slot bold"><div>יום רביעי</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>18:30<br/>BJJ-GI</div></div>
          <div class="slot double"><div>19:30<br/><br/>NO&nbsp;GI<br/>מתחילים<br/>מתקדמים</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Thursday -->
        <div class="day-column">
          <div class="slot bold"><div>יום חמישי</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>אימון בסיס</div></div>
          <div class="slot"><div>BJJ - GI</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Friday -->
        <div class="day-column">
          <div class="slot bold"><div>יום שישי</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot friday-highlight"><div>11:00<br/>מזרון פתוח</div></div>
          <div class="slot"><div>12:00<br/>Mobility</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
        </div>

        <!-- Saturday -->
        <div class="day-column">
          <div class="slot bold"><div>יום שבת</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
          <div class="slot"><div>.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section testa" aria-label="המלצות">
    <div class="wrapper testamonials">
      <div class="spacere fade-in">
        <h2>יש אנשים מכורים לספורט הזה</h2>
      </div>
      <div class="testemonials-wrap stagger">
        <div class="person fade-in">
          <div class="testi-wrap">
            <img src="/images/testimonial-yona.webp" alt="יונה, מתאמן גיו גיטסו" class="testi-img" width="327" height="308" loading="lazy" />
          </div>
          <div class="testi-text">
            <blockquote>"כל אימון גומר אותך פיזית, אתה מסיים אותו מזיע ועייף אבל בתחושת הצלחה והישג. והתחושה הזאת מחזיקה כמה ימים"</blockquote>
            <div class="testa-name">יונה, מהנדס הנדסות</div>
          </div>
        </div>
        <div class="person fade-in">
          <div class="testi-wrap">
            <img src="/images/testimonial-yonatan.webp" alt="יונתן, מתאמן גיוגיטסו" class="testi-img" width="367" height="308" loading="lazy" />
          </div>
          <div class="testi-text">
            <blockquote>"זה ממש שינה לי את החיים, חשבתי שאני שונא את כל סוגי הספורט ולנצח אשאר בטטה, אבל גיוגיוטסו מאתגר גם את הגוף וגם את המוח אז אני מכור"</blockquote>
            <div class="testa-name">יונתן, איש שיווק</div>
          </div>
        </div>
        <div class="person fade-in">
          <div class="testi-wrap">
            <img src="/images/testimonial-simcha.webp" alt="שמחה, חגורה כחולה" class="testi-img" width="343" height="308" loading="lazy" />
          </div>
          <div class="testi-text">
            <blockquote>"עברתי בכמה מכונים בחיי אבל נשארתי אצל רועי נאמן כי מרגישים את המקצוענות ואת המסירות שלו, כל החיים שלו ג'יוגיטסו - מומחה מאוד גדול ומורה מצויין"</blockquote>
            <div class="testa-name">שמחה, כלכלן</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Teacher -->
  <section class="section teacher" aria-label="המאמן">
    <div class="wrapper teacher">
      <div class="text-wrapper fade-in-right">
        <h2>רועי נאמן</h2>
        <p class="paragraph-2">רועי נאמן – התמקצע בתורה במכון "באהה גרייסי פיטבול" בסן-דייגו בשנות ה-2000 המוקדמות. לאחר 8 שנים בקליפורניה בהם היתחרה והיתמקצע, חזר לארץ כחגורה שחורה, ייסד את טים פיטבול ישראל והחל ללמד את השיטה. כיום דאן 2 בג'יו-ג'יטסו תחת ג'ואו קוניה, דאן 3 תחת ריקרדו בובמן. רועי נאמן לוחם MMA מקצועני בעברו, עם ניסיון של למעלה מ-100 טורנירי הכנעות עם ובלי חליפה, זכה בעשרות מדליות בתחרויות בינלאומיות, וב 2007 זכה שלישי בעולם בסגנון No-Gi. מאמן ותיק ומוסמך וינגייט.</p>
      </div>
      <div class="image-wrapper fade-in-left">
        <img src="/images/roi-teacher.webp" width="465" height="467" alt="רועי נאמן מורה לגיוגיטסו ברזילאי בתל אביב לכל הרמות" class="teacher-img" loading="lazy" />
      </div>
    </div>
  </section>

  <!-- Why Now -->
  <section class="section whynow" aria-label="למה להתחיל עכשיו">
    <div class="footer-image">
      <img src="/images/seminar-group.webp" loading="lazy" alt="מתאמנים בסמינר MMA במכון גיוגיטסו" width="1600" height="1066" />
    </div>
    <div class="wrapper why-now">
      <div>
        <h3 class="fade-in">למה להתחיל ללמוד עכשיו?</h3>
        <p class="paragraph-2">כולנו עשינו את זה בעבר, מוצאים תירוצים וסיבות להמנע מפעילות גופנית. זה לא קל לפנות זמן לעצמנו, ולהשקיע בכושר ותנועה.<br/><br/>אנחנו מבינים כמה זה קשה למצוא זמן לעצמך בין העיסוקים בעבודה, בחיים ובמשפחה. אנו גם מבינים את התסכול כשאין זמן לאורח חיים בריא - אבל מגיע לך יותר.<br/><br/>אצלנו מתאמנים גברים ונשים שמכיניסים כושר, תנועתיות, קרביות וביטחון עצמי לחיים, מפתחים הרגלים חיוביים, מייצרים איזון פנימי ותחושה טובה בין אימון לאימון.</p>
        <a href="#contact" class="main-cta">לתיאום אימון ניסיון</a>
      </div>
    </div>
  </section>

  <!-- How to Start -->
  <section class="section" aria-label="איך מתחילים">
    <div class="wrapper start">
      <div class="title-wrap fade-in">
        <h2>איך מתחילים?</h2>
        <div class="text-block">זה בכלל לא מסובך ובשלושה שלבים פשוטים אפשר להתחיל להחזיר את האיזון לחיים:</div>
      </div>
      <div class="stag-er stagger">
        <div class="stage _01 fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">01</div></div>
          <h3 class="padd">שיחת התאמה &gt;&gt;</h3>
          <p>האימון מתרחש ברובו על הקרקע ומפעיל הרבה שרירים במקביל, כך נוצר אימון אפקטיבי שמזיז את כל הגוף.</p>
        </div>
        <div class="stage fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">02</div></div>
          <h3 class="padd">אימון ניסיון &gt;&gt;</h3>
          <p>האימון מתרחש ברובו על הקרקע ומפעיל הרבה שרירים במקביל, כך נוצר אימון אפקטיבי שמזיז את כל הגוף.</p>
        </div>
        <div class="stage _03 fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">03</div></div>
          <h3 class="padd">התמדה ושיפור &gt;&gt;</h3>
          <p>האימון מתרחש ברובו על הקרקע ומפעיל הרבה שרירים במקביל, כך נוצר אימון אפקטיבי ושמזיז את כל הגוף.</p>
        </div>
        <div class="wide">
          <a href="#contact" class="main-cta">לתיאום אימון ניסיון</a>
        </div>
      </div>
    </div>
  </section>

  <!-- What You'll Learn -->
  <section class="section no-margin" aria-label="מה לומדים">
    <div class="wrapper what-learn">
      <div class="title-wrap align-right fade-in">
        <h2>מה לומדים בטים פיטבול</h2>
        <div class="text-block">כושר, תנועתיות, קרביות וביטחון עצמי. מתאים לגברים ולנשים, לכל הרמות ולכל הגילאים – חובבני ותחרותי (חניכים זוכי מדליות בתחרויות שונות), קבוצות ושיעורים פרטיים.</div>
      </div>
      <div class="lessons-div stagger">
        <div class="lesson fade-in">
          <img src="/images/lesson-base.webp" alt="שיעורי בסיס - רועי נאמן מברך את תלמידיו" class="lesson-img" width="1200" height="773" loading="lazy" />
          <h3>שיעורי בסיס</h3>
          <p>העקרונות החשובים עליהם בנויה השיטה, החל מעמדות מוצא ועד ההכנעות הכי חשובות בספורט ועבור הגנה עצמית. איך להפיל, להשיג עמדת שליטה על הקרקע ולהכניע – ואיך להתגונן מפני כל אלה.</p>
        </div>
        <div class="lesson fade-in">
          <img src="/images/lesson-advanced.webp" alt="ג'יו ג'יטסו מתקדמים - הדגמה של סוויפ" class="lesson-img" width="1600" height="1066" loading="lazy" />
          <h3>ג'יו ג'יטסו למתקדמים</h3>
          <p>טכניקות מתקדמות להגדלת ארגז הכלים, יותר גלגולים (ה"קרבות" שלנו, בהתנגדות גבוהה) וקצב יותר מהיר.</p>
        </div>
        <div class="lesson fade-in">
          <img src="/images/lesson-mma.webp" alt="MMA - טייקדאון ואחיזה" class="lesson-img" width="1200" height="804" loading="lazy" />
          <h3>MMA - אומנויות לחימה משולבות</h3>
          <p>באימונים האלה אנחנו מוסיפים להיאבקות ולג'יו-ג'יטסו את מכות הידיים והרגליים, האיגרוף והמואי-תאי, וכמו כן את עבודת המכות על הקרקע. מתאים למקצוענים ולחובבנים, לאלה שרוצים להילחם עבור שכר ולאלה שמעוניינים לשפר את יכולת ההגנה העצמית.</p>
        </div>
        <div class="lesson fade-in">
          <img src="/images/lesson-women.webp" alt="ג'יו ג'יטסו לנשים - אימון אומנויות לחימה" class="lesson-img" width="1200" height="800" loading="lazy" />
          <h3>ג'יו ג'יטסו לנשים</h3>
          <p>בהדרכת נטלי לוריא, האשה החגורה שחורה הראשונה בשיטה בישראל. (כמובן שהנשים מוזמנות גם לכלל האימונים).</p>
        </div>
        <div class="lesson fade-in">
          <img src="/images/lesson-nogi.webp" alt="NO GI - אימון היאבקות ללא חליפה" class="lesson-img" width="1200" height="737" loading="lazy" />
          <h3>שיעורים ללא חליפה - NO&nbsp;GI</h3>
          <p>אימוני היאבקות הכנעות מתקדמים ללא חליפה, No-Gi. סגנון יותר חופשי ודינמי.</p>
        </div>
        <div class="lesson fade-in">
          <img src="/images/lesson-kids.webp" alt="ג'יוגיטסו לילדים - ספורט ואומנויות לחימה" class="lesson-img" width="1753" height="1178" loading="lazy" />
          <h3>ג'יוגיטסו לילדים</h3>
          <p>כל מה שטוב בג'יו-ג'יטסו, עם דגש על כבוד הדדי, משמעת, שיפור הריכוז והביטחון העצמי. אף פעם לא מוקדם מדי להתחיל.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why BJJ -->
  <section class="section reasons-section" aria-label="למה ג'יו גיטסו">
    <div class="wrapper reasons-wrap">
      <div class="title-wrap fade-in">
        <h2>למה ג'יו גיטסו?</h2>
      </div>
      <div class="reasons-grid stagger">
        <div class="reason fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">01</div></div>
          <div class="text-div">
            <h3>אימון אינטנסיבי</h3>
            <p>האימון מתרחש ברובו על הקרקע ומפעיל הרבה שרירים במקביל, כך נוצר אימון אפקטיבי שמזיז את כל הגוף.</p>
          </div>
        </div>
        <div class="reason fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">02</div></div>
          <div class="text-div">
            <h3>ביטול מימד הכוח</h3>
            <p>היתרון הגדול של הספורט הוא שלא צריך להיות הכי חזק בשביל לנצח, טכניקה טובה מנצחת כוח.</p>
          </div>
        </div>
        <div class="reason fade-in">
          <div class="orange" aria-hidden="true"><div class="big-no">03</div></div>
          <div class="text-div">
            <h3>מאתגר את השכל</h3>
            <p>האימון המנטלי והחידות הבלתי פוסקות מעסיקות יותר מהקושי הפיזי. ג'יו-ג'יטסו זה בית-ספר לפתרון בעיות</p>
          </div>
        </div>
      </div>
      <div class="wrapper">
        <div class="wide">
          <a href="#contact" class="main-cta">לתיאום אימון ניסיון</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Group photo -->
  <div>
    <img src="/images/group-photo.webp" loading="lazy" alt="קבוצת מתאמנים אחרי אימון במכון פיטבול ישראל" width="1600" height="1066" style="width:100%;display:block;" />
  </div>

  <!-- Contact -->
  <div>
    <section id="contact" class="section contact" aria-label="צור קשר">
      <div class="wrapper contact">
        <div class="contact-inner">
          <div class="contact-logo-wrap">
            <img src="/images/logo.svg" alt="פיטבול ישראל" class="contact-logo" width="200" height="200" loading="lazy" />
          </div>
          <div>
